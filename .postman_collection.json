{
  "info": {
    "name": "Fragments API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Google Auth URL",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/google/url?state=random123",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "google", "url"],
              "query": [
                {
                  "key": "state",
                  "value": "random123"
                }
              ]
            }
          }
        },
        {
          "name": "Google Callback",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"GOOGLE_AUTH_CODE\",\n  \"state\": \"random123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/google",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "google"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Fragments",
      "item": [
        {
          "name": "Create Fragment",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "text",
                  "value": "My first fragment",
                  "type": "text"
                },
                {
                  "key": "lat",
                  "value": "55.7558",
                  "type": "text"
                },
                {
                  "key": "lng",
                  "value": "37.6173",
                  "type": "text"
                },
                {
                  "key": "photos",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "sound",
                  "type": "file",
                  "src": []
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/fragments",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments"]
            }
          }
        },
        {
          "name": "Get Fragment by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/fragments/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "REPLACE_WITH_FRAGMENT_ID"
                }
              ]
            }
          }
        },
        {
          "name": "List Fragments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/fragments?lat=55.7558&lng=37.6173&radius=1000",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments"],
              "query": [
                {
                  "key": "lat",
                  "value": "55.7558"
                },
                {
                  "key": "lng",
                  "value": "37.6173"
                },
                {
                  "key": "radius",
                  "value": "1000"
                }
              ]
            }
          }
        },
        {
          "name": "Update Fragment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"text\": \"Updated fragment text\",\n  \"lat\": 55.7558,\n  \"lng\": 37.6173\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/fragments/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "REPLACE_WITH_FRAGMENT_ID"
                }
              ]
            }
          }
        },
        {
          "name": "Delete Fragment",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/fragments/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments", ":id"],
              "variable": [
                {
                  "key": "id",
                  "value": "REPLACE_WITH_FRAGMENT_ID"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/users/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"New Name\",\n  \"avatar_url\": \"http://example.com/avatar.jpg\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/profile",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Found Fragments",
      "item": [
        {
          "name": "Mark Fragment as Found",
          "request": {
            "method": "POST",
            "url": {
              "raw": "{{base_url}}/api/fragments/REPLACE_WITH_FRAGMENT_ID/found",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments", ":id", "found"],
              "variable": [
                {
                  "key": "id",
                  "value": "REPLACE_WITH_FRAGMENT_ID"
                }
              ]
            }
          }
        },
        {
          "name": "Get Found Fragments",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/fragments/found",
              "host": ["{{base_url}}"],
              "path": ["api", "fragments", "found"]
            }
          }
        }
      ]
    },
    {
      "name": "Achievements",
      "item": [
        {
          "name": "Get All Achievements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/achievements",
              "host": ["{{base_url}}"],
              "path": ["api", "achievements"]
            }
          }
        },
        {
          "name": "Get My Achievements",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/achievements/mine",
              "host": ["{{base_url}}"],
              "path": ["api", "achievements", "mine"]
            }
          }
        }
      ]
    }
  ]
}
